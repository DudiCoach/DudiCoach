{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/mimo-v2.5-free",
  "small_model": "opencode/mimo-v2.5-free",
  "default_agent": "build",
  "shell": "/bin/zsh",
  "share": "disabled",
  "autoupdate": false,

  "instructions": [
    "AGENTS.md"
  ],

  "agent": {
    "plan": {
      "model": "anthropic/claude-opus-4-7",
      "description": "Planning agent. Uses Anthropic Opus 4.7 for complex reasoning, architecture decisions, and multi-step planning.",
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    },
    "build": {
      "model": "opencode/mimo-v2.5-free",
      "description": "Build agent. Uses Mimo 2.5 Free for code generation, edits, and implementation tasks.",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    }
  },

  "plugin": [
    "@ex-machina/opencode-anthropic-auth@1.8.0"
  ],

  "permission": {
    "edit": "allow",
    "bash": {
      "git *": "allow",
      "npm *": "allow",
      "npx *": "allow",
      "gh *": "allow",
      "firebase *": "allow",
      "gcloud *": "allow",
      "*": "ask"
    }
  },

  "compaction": {
    "auto": true,
    "tail_turns": 15
  },

  "tool_output": {
    "max_lines": 200,
    "max_bytes": 8192
  }
}
